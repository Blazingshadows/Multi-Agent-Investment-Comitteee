# Copy to .env (gitignored) and fill in what you have. llm_router tries
# providers in this order and falls back automatically if one is
# unavailable/rate-limited — you only strictly need one of these to start.

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Local Ollama on the networked 24GB GPU box (OpenAI-compatible endpoint)
OLLAMA_REMOTE_URL=http://<gpu-box-host>:11434/v1
OLLAMA_REMOTE_MODEL=qwen2.5:14b

# Local Ollama on this machine — last-resort fallback
OLLAMA_LOCAL_URL=http://localhost:11434/v1
OLLAMA_LOCAL_MODEL=qwen2.5:7b
